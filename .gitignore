*.local.md

# E2E (Playwright)
e2e/node_modules/
e2e/artifacts/
e2e/.auth/
e2e/test-results/
apps/backend/.cockpit-acl-poc.json
TEST-CREDENTIALS.local.md

# Superpowers local tooling/session state (brainstorm scratch, server pids/logs) — never commit
.superpowers/
# DNA SDLC board — per-workstation pointer (written by `dna sdlc story start`)
.dna/active-story.txt

# Hosted containers' baked DNA scope — BUILD ARTIFACT, not source. The single
# source of truth is apps/backend/.dna; scripts/sync-hosted-scope.sh mirrors it
# into each hosted build context before the image build (ADR-013). Never commit.
apps/hosted-*/.dna/
