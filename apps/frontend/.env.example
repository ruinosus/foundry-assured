# Frontend env — copy to apps/frontend/.env.local.
# The CopilotKit runtime (app/api/copilotkit) proxies to the backend AG-UI endpoints. In local
# dev you normally only set BACKEND_URL (or leave the default) — every per-domain URL derives
# from it. Value after `=` is the code DEFAULT. "(opt)" = safe to omit.

# ─── Backend base — all domain AG-UI endpoints derive from this ───
BACKEND_URL=http://localhost:8000

# (opt) Per-endpoint overrides — only if a domain/endpoint runs somewhere else than BACKEND_URL:
#   AGUI_URL              default ${BACKEND_URL}/helpdesk
#   HOSTED_AGUI_URL       default ${BACKEND_URL}/helpdesk-hosted
#   PLATFORM_HOSTED_AGUI_URL  default ${BACKEND_URL}/platform-hosted
#   <DOMAIN>_AGUI_URL     per-domain (e.g. COCKPIT_AGUI_URL, SELFWIKI_AGUI_URL, PLATFORM_AGUI_URL)
# AGUI_URL=http://localhost:8000/helpdesk

# ─── Entra ID sign-in ───
# Leave blank to run WITHOUT sign-in (matches the backend's no-auth fallback).
NEXT_PUBLIC_ENTRA_TENANT_ID=
NEXT_PUBLIC_ENTRA_SPA_CLIENT_ID=
NEXT_PUBLIC_ENTRA_API_CLIENT_ID=

# ─── Demo mode ───
NEXT_PUBLIC_DEMO_MODE=                                 # (opt) "true" → canned data, no backend/Foundry needed
