# Backend env — copy to apps/backend/.env and fill.
# Most values come from `azd env get-values` after `azd up`. Auth is via DefaultAzureCredential
# (run `az login` / `azd auth login`) — NO keys here.
#
# Convention below: a value after `=` is the code DEFAULT (safe to leave). A blank `=` marked
# "REQUIRED" must be set. "(opt)" = safe to omit. A MINIMAL local helpdesk run needs only the
# REQUIRED ones + Entra (or blank Entra to run without sign-in).
#
# NOTE (naming): the ACL config was renamed off the cockpit product name to generic ACL_* (it's
# used by cockpit AND selfwiki). The old COCKPIT_ACL_* names still work (deprecated alias). The
# docbundle ingest is now `app.knowledge.ingest_docbundles` (shim keeps `ingest_cockpit` working).
# See docs/superpowers/specs/2026-07-02-generic-config-naming-rename-design.md.

# ═══════════════ Foundry (Phase 0) ═══════════════
FOUNDRY_PROJECT_ENDPOINT=                              # REQUIRED — https://<account>.services.ai.azure.com/api/projects/<project>
FOUNDRY_MODEL=gpt-5-mini
FOUNDRY_EMBEDDING_MODEL=text-embedding-3-small
AZURE_AI_OPENAI_ENDPOINT=                              # REQUIRED (KB + eval) — https://<account>.openai.azure.com

# ═══════════════ Azure AI Search + Storage — the KB + corpus (Phase 1) ═══════════════
AZURE_SEARCH_ENDPOINT=                                 # REQUIRED — https://<svc>.search.windows.net
AZURE_SEARCH_KNOWLEDGE_BASE=helpdesk-kb                # the helpdesk domain KB
AZURE_STORAGE_ACCOUNT=                                 # REQUIRED for ingest
AZURE_STORAGE_RESOURCE_ID=                             # REQUIRED for ingest — /subscriptions/.../storageAccounts/<name>
AZURE_STORAGE_CONTAINER=corpus                         # helpdesk corpus container

# ═══════════════ Foundry memory (Phase 3) ═══════════════
FOUNDRY_MEMORY_STORE=helpdesk-memory

# ═══════════════ Entra ID + On-Behalf-Of (Phase 3) ═══════════════
# Leave the four ENTRA_* blank to run WITHOUT sign-in (DefaultAzureCredential fallback).
ENTRA_TENANT_ID=                                       # tenant id (auth off if blank)
ENTRA_API_CLIENT_ID=                                   # backend API app registration (token audience)
ENTRA_API_CLIENT_SECRET=                               # its client secret (for OBO)
ENTRA_SPA_CLIENT_ID=                                   # frontend SPA app registration (reference)
DEPLOYMENT_MODE=self_hosted                            # self_hosted | dedicated | shared
FRONTEND_ORIGIN=http://localhost:3000                  # CORS allow-origin
ONBOARDING_ALLOWED_TIDS=                               # (opt) shared mode: comma-sep Entra tids allowed to onboard

# ═══════════════ Per-document ACL — access is DATA (RULE #6) ═══════════════
# APP_USERS_GROUP_ID is the group of everyone with app access; it doubles as the selfwiki PRIVATE
# AUDIENCE. If empty, /selfwiki fails closed (0 docs). See
# docs/superpowers/specs/2026-07-02-selfwiki-acl-safe-refresh-design.md.
APP_USERS_GROUP_ID=                                    # Entra group object-ID of app users (= selfwiki audience)
ACL_GROUP_MAP=                                         # (opt) extra groups "name:objectId,name:objectId"
ACL_PUBLIC_GROUP=                                      # (opt) object-ID mapped to the name "public"
ACL_INTERNAL_GROUP=                                    # (opt) → "internal"
ACL_CONFIDENTIAL_GROUP=                                # (opt) → "confidential"
ACL_DEFAULT_GROUPS=                                    # (opt) groups for docs w/ no declared access (e.g. "public"); empty = fail-closed
ACL_CLASSIFICATION=                                    # (opt) path to {doc-key:[group,...]} json (gitignored)
# (deprecated aliases still accepted: COCKPIT_ACL_GROUP_MAP / _PUBLIC_GROUP / _INTERNAL_GROUP / _CONFIDENTIAL_GROUP / _DEFAULT_GROUPS / _CLASSIFICATION)

# ═══════════════ Cockpit domain KB (2nd domain — the Cockpit product docs) ═══════════════
COCKPIT_SEARCH_KNOWLEDGE_BASE=cockpit-kb               # ACTIVE cockpit KB (flip to the -si- twin to cut over)
COCKPIT_SEARCH_INDEX=cockpit-docbundles-ks-index
COCKPIT_STORAGE_CONTAINER=cockpit-corpus
COCKPIT_SEARCHINDEX_KNOWLEDGE_BASE=cockpit-si-kb       # native-path (searchIndex) twin KB
COCKPIT_SEARCHINDEX_KNOWLEDGE_SOURCE=cockpit-docbundles-si-ks
COCKPIT_DOCBUNDLES_PATH=                               # (opt) path to the aap-kb docbundles/ dir (internal corpus)
COCKPIT_HOSTED_AGENT_NAME=cockpit-expert              # (opt) legacy hosted twin (grounded runs live-OBO now)

# ═══════════════ Selfwiki domain KB (this repo's own deep-wiki — private, audience = app-users) ═══════════════
SELFWIKI_SEARCH_KNOWLEDGE_BASE=                        # (opt) legacy blob KB name (blank; native path is active)
SELFWIKI_SEARCH_INDEX=selfwiki-docbundles-ks-index
SELFWIKI_STORAGE_CONTAINER=selfwiki-corpus
SELFWIKI_SEARCHINDEX_KNOWLEDGE_BASE=selfwiki-si-kb     # the ACTIVE native-path KB
SELFWIKI_SEARCHINDEX_KNOWLEDGE_SOURCE=selfwiki-docbundles-si-ks
SELFWIKI_HOSTED_AGENT_NAME=selfwiki-expert            # (opt) legacy hosted twin

# ═══════════════ Hosted agents (Phase 6 / packaging) ═══════════════
HOSTED_AGENT_NAME=helpdesk-concierge
PLATFORM_HOSTED_AGENT_NAME=platform-concierge

# ═══════════════ Platform domain (tool-driven, MCP) ═══════════════
MCP_ENABLED=false                                     # true → mounts /platform (first-party MS MCP servers)
MCP_LEARN_URL=https://learn.microsoft.com/api/mcp
MCP_ADO_ORGANIZATION=                                 # (opt) per-tenant Azure DevOps org
MCP_GITHUB_PAT=                                       # (opt) per-tenant GitHub PAT
MCP_AZURE_URL=                                        # (opt) self-hosted Azure MCP url

# ═══════════════ Shared (multi-tenant) mode — only when DEPLOYMENT_MODE=shared ═══════════════
TENANT_STORE_BACKEND=table                            # table | memory
TENANT_STORE_ACCOUNT_URL=                             # Azure Table endpoint (table backend)
TENANT_STORE_TABLE=tenants

# ═══════════════ Ingest CLI (app.knowledge.ingest_docbundles / .ingest) — override per corpus ═══════════════
KB_KNOWLEDGE_SOURCE=cockpit-docbundles-ks             # (opt) knowledge source name the ingest builds
KB_DOMAIN_LABEL=Avanade Cockpit platform              # (opt) label used in KB descriptions
COCKPIT_DOCBUNDLES=                                   # (opt) docbundles dir for the ingest (else uses the config path)
SEARCH_API_VERSION=2026-05-01-preview                 # (opt)

# ═══════════════ Observability + tuning (all optional) ═══════════════
APPLICATIONINSIGHTS_CONNECTION_STRING=                # (opt) OpenTelemetry traces → App Insights
INGEST_CALL_TIMEOUT=                                  # (opt) per-call timeout seconds for the ingest
INGEST_DEBUG=                                         # (opt) 1 = verbose ingest logging
USD_BRL=                                              # (opt) USD→BRL rate for cost display
